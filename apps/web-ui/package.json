{
  "name": "rclone-on-cloud-web-ui",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "build": "NODE_ENV=prod ng build",
    "serve": "serve -s dist/rclone-on-cloud-web-ui/browser -l 4200",
    "watch": "ng build --watch --configuration development",
    "test": "NG_APP_ENV=test ng test --watch=false --coverage",
    "test:in": "NG_APP_ENV=test ng test --watch=false --coverage --include",
    "lint": "ng lint && prettier --check \"src/**/*.{ts,html}\"",
    "lint:fix": "ng lint --fix && prettier --write \"src/**/*.{ts,html}\""
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/component-store": "^21.0.1",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/operators": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "buffer": "^6.0.3",
    "daisyui": "^5.5.19",
    "http-server": "^14.1.1",
    "lru-cache": "^11.2.7",
    "ngx-cookie-service": "^21.3.1",
    "pretty-bytes": "^7.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@ngx-env/builder": "^21.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@vitest/coverage-v8": "^4.1.0",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
